# AlphaEarth Cesium 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ==================== GEE 配置 ====================
# 必需：您的 GEE 用户路径（用于存放缓存 Assets）
GEE_USER_PATH=users/your_username/aef_demo

# 可选：GEE 服务账号配置（生产环境推荐）
# EE_SERVICE_ACCOUNT=xxx@yyy.iam.gserviceaccount.com
# EE_PRIVATE_KEY_FILE=/path/to/service-account-key.json

# ==================== 服务器配置 ====================
# 后端 API 配置
API_HOST=127.0.0.1
API_PORT=8505

# 前端配置
FRONTEND_PORT=8504

# ==================== Cesium 配置 ====================
# Cesium Ion Access Token（可选，提升服务质量）
# 获取地址: https://ion.cesium.com/tokens
# VITE_CESIUM_TOKEN=your_cesium_ion_access_token_here

# Optional: Cesium Ion Photorealistic 3D Tiles
# Fill with the numeric asset id from https://ion.cesium.com/assets/<id>
# VITE_ION_PHOTOREALISTIC_ASSET_ID=2275207

# Optional: force Ion proxy via backend (/api/ion/*)
# VITE_ION_PROXY=1

# Optional: basemap selection
# - default: let Cesium choose (often Bing when Ion token exists)
# - osm: use backend same-origin OSM proxy (/api/basemap/osm/*) as base layer
# - grid: force a local grid base layer
# - google_official: use Google Map Tiles API (2D satellite) via backend /api/google-tiles
# - google_xyz: (test-only) use mt*.google.com/vt XYZ satellite tiles directly (unofficial / may change)
# VITE_BASEMAP=osm

# Optional: Google Map Tiles API (official 2D basemap)
# Recommended (production): set backend-only GOOGLE_MAPS_API_KEY so the browser never needs to embed a key.
# GOOGLE_MAPS_API_KEY=your_google_maps_platform_api_key
# Optional (dev only): if you cannot set backend env, provide key to the frontend.
# NOTE: values in VITE_* are bundled into frontend assets and SHOULD NOT be used for secrets.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_platform_api_key

# To enable official Google 2D satellite basemap:
# VITE_BASEMAP=google_official

# Test-only: Google XYZ (unofficial) satellite basemap.
# WARNING: this URL pattern is undocumented and may change; ensure compliance with your policies.
# VITE_BASEMAP=google_xyz
# VITE_GOOGLE_XYZ_ENABLE=1
# VITE_GOOGLE_XYZ_LYRS=s


# Optional: Photorealistic-only demo mode
# When enabled AND VITE_ION_PHOTOREALISTIC_ASSET_ID is set, the app will remove all 2D
# imagery layers and hide the ellipsoid globe (prevents the common "patchwork" look).
# Note: outside photorealistic coverage, the scene background may appear empty.
# VITE_PHOTOREALISTIC_ONLY=1

# Optional (production guard): disable Cesium default imagery to avoid any
# direct Bing/virtualearth.net requests (CORS/502 in some networks).
# When enabled, CesiumViewer forces a local GridImageryProvider as baseLayer.
# VITE_DISABLE_DEFAULT_IMAGERY=1

# Backend-only (production): optional Ion token for /api/debug/ion
# ION_ACCESS_TOKEN=your_cesium_ion_access_token_here

# ==================== LLM 配置（可选） ====================
# 用于 /api/report 生成《区域空间监测简报》
# DashScope OpenAI-compatible: https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=your_dashscope_api_key
# LLM_MODEL=qwen-plus
# LLM_TIMEOUT_S=12
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=512

# ==================== 开发配置 ====================
# 是否为测试模式
TESTING=0

# 日志级别 (DEBUG, INFO, WARNING, ERROR)

# ========== tile proxy hardening (recommended for small servers) ==========
# Reduce upstream fanout; prevents memory/CPU spikes under Cesium tile bursts.
TILE_UPSTREAM_MAX_CONCURRENCY=16
# Bound in-memory tile cache size to avoid OOM kills (bytes).
TILE_LRU_MAX_BYTES=67108864

# ========== uvicorn ==========
# For production, prefer 1 worker on small instances.
UVICORN_WORKERS=1
LOG_LEVEL=INFO

# ========== basemap proxy (optional) ==========
# Backend provides `/api/bing-proxy?url=...` (strict allowlist) for Bing tiles.
# Note: enabling/disabling the default imagery is handled in the frontend.
