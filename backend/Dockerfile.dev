FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app/backend

# Install dev/test deps (includes runtime deps via -r requirements.txt)
COPY requirements.txt requirements-dev.txt ./
RUN python -m pip install --upgrade pip \
    && pip install -r requirements-dev.txt

# Copy backend source (will be overridden by bind-mount in docker-compose.dev)
COPY . .

EXPOSE 8505

CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8505", "--reload"]
