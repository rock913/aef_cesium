FROM node:20.19-alpine

WORKDIR /app

# Base layer deps (helps caching when not bind-mounting)
COPY package.json package-lock.json ./
RUN npm ci

# Dev container relies on bind mount for source code.
EXPOSE 8404

# IMPORTANT: docker-compose.dev.yml mounts /app/node_modules as a named volume.
# That volume can exist while missing packages (e.g., after package.json changes),
# so checking only for the directory is insufficient.
CMD ["sh", "-lc", "set -e; node -e \"require.resolve('vite'); require.resolve('three'); require.resolve('gsap')\" >/dev/null 2>&1 || npm ci; node -e \"require.resolve('vite'); require.resolve('three'); require.resolve('gsap')\" >/dev/null 2>&1; npm run dev -- --host 0.0.0.0 --port ${FRONTEND_PORT:-8404}"]
